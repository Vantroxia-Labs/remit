# =================================================================
# ENVIRONMENT VARIABLES - E-INVOICE INTEGRATOR SERVICE PORTAL API (SaaS)
# =================================================================

# DotNetEnv loads this file at startup from the project working directory.
# ASP.NET Core maps double-underscore (__) to section hierarchy, e.g.:
#   Jwt__SecretKey  →  configuration["Jwt:SecretKey"]
#
# Generate secure keys with:  .\remit\scripts\generate-secrets.ps1
# =============================================================================

# =================================================================
# GITHUB CONFIGURATION
# =================================================================
GitHub__Token=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

# =================================================================
# SUPPORT & ADMIN CONFIGURATION
# =================================================================
Support__Email=support@ng.aegis.com
aegisAdmin__Email=admin@ng.aegis.com

# ─── ASP.NET Core ─────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
# Portal API dev port (must match VITE_API_BASE_URL in admin/.env)
ASPNETCORE_URLS=http://localhost:5242

# ─── Database ─────────────────────────────────────────────────────────────────
# ASP.NET maps ConnectionStrings__DefaultConnection → ConnectionStrings:DefaultConnection
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=aegis_eInvoicing;Username=postgres;Password=jd6~Se:j7-;FRY7;Pooling=true;SSL Mode=Prefer;Trust Server Certificate=true

# ─── JWT ──────────────────────────────────────────────────────────────────────
Jwt__SecretKey=70f3eae2-6666-4e54-969e-012ade7fd8ae
Jwt__Issuer=AegisEInvoicing
Jwt__Audience=AegisEInvoicingUsers
Jwt__ExpirationInMinutes=60
Jwt__RefreshTokenExpirationInDays=7

# ─── Encryption ───────────────────────────────────────────────────────────────
# Key: exactly 32 UTF-8 characters (AES-256 = 256 bits = 32 bytes)
# IV:  exactly 16 UTF-8 characters (AES block size = 128 bits = 16 bytes)
Encryption__Key=DevEncryptKey32BytesAES256!!2026
Encryption__Iv=DevEncryptionIV!

# Payload encryption key (base64-encoded, must decode to exactly 32 bytes)
# Used by PayloadDecryptionMiddleware for /auth/login etc.
# Must match what the admin frontend uses to encrypt login payloads.
PAYLOAD_ENCRYPTION_KEY=RGV2UGF5bG9hZEVuY3J5cHRLZXkzMkJ5dGVzITIwMjY=

# ─── FIRS / NRS API ───────────────────────────────────────────────────────────
# FIRSApiConfiguration = managed config (DB-backed, used by AegisAdmin portal)
FIRSApiConfiguration__DefaultConfiguration__BaseUrl=https://eivc-k6z6d.ondigitalocean.app
FIRSApiConfiguration__DefaultConfiguration__ApiKey=91c10232-d376-49d7-8044-961d2b67aae7
FIRSApiConfiguration__DefaultConfiguration__ApiSecret=p8Ix7eyohWeI7nSKgDGyn3Oed2jnTNcrMgiTHshB4pKlERReWJq1GycRXtIfiaOGAIuOKYbHmo31xVIacgQFzue915xa5ANiNZqK
FIRSApiConfiguration__DefaultConfiguration__Environment=Development

# FIRSHttpClient = direct HTTP client options (validated on startup)
FIRSHttpClient__BaseUrl=https://eivc-k6z6d.ondigitalocean.app

# InterswitchHttpClient = Interswitch access-point HTTP client (validated on startup)
# Set a real URL when you have Interswitch sandbox credentials; placeholder for now.
InterswitchHttpClient__BaseUrl=https://api.interswitch.com

# ─── Email ────────────────────────────────────────────────────────────────────
# Dev: use MailHog (localhost:1025) or leave Provider=none to skip sending
EmailSettings__Provider=mailkit
MailKit__SmtpServer=localhost
MailKit__SmtpPort=1025
MailKit__Username=dev
MailKit__Password=dev
MailKit__UseSsl=false
MailKit__DefaultFromEmail=dev@localhost
MailKit__DefaultFromName=Aegis Dev

# ─── SFTPGo ───────────────────────────────────────────────────────────────────
# Portal API calls SFTPGo's admin REST API to provision user accounts/folders.
# Endpoint = SFTPGo admin API (port 8090 default).
# Host/Port below are the SFTP file-transfer port (2222 default in dev).
SFTPGoService__Endpoint=http://localhost:8090
SFTPGoService__BaseDirectory=C:/ftproot
SFTPGoService__Host=localhost
SFTPGoService__Port=2222
SFTPGoService__Username=sftpgo
SFTPGoService__Password=sftpgo
SFTPGoService__MaintenanceSftpUsername=admin
SFTPGoService__MaintenanceSftpPassword=admin

# ─── ERP API (internal service call) ─────────────────────────────────────────
ErpApi__BaseUrl=http://localhost:56257

# ─── App URLs ─────────────────────────────────────────────────────────────────
App__BaseUrl=http://localhost:5242
App__PortalUrl=http://localhost:3000

# ─── CORS ─────────────────────────────────────────────────────────────────────
# IMPORTANT: must list every origin the admin frontend runs on.
# Portal API CORS is configured from Cors:AllowedOrigins in appsettings.json
# (already includes localhost:3000, localhost:2025, localhost:3001).
# Add extras here using the indexed array format if needed:
# Cors__AllowedOrigins__6=http://localhost:4000

# ─── Paystack ─────────────────────────────────────────────────────────────────
# appsettings.json already has test keys hardcoded; override here for prod.
# Paystack__SecretKey=sk_live_...
# Paystack__WebhookSecret=whsec_...

# ─── Monitoring (optional) ────────────────────────────────────────────────────
# Overrides SigNoz:Endpoint from appsettings.json (which has a ${} placeholder)
SigNoz__Endpoint=http://localhost:4317
