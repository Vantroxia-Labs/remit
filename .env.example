# =================================================================
# ENVIRONMENT VARIABLES TEMPLATE - E-INVOICE INTEGRATOR
# =================================================================
# Copy this file to .env and fill in your values
# DO NOT commit the actual .env file to version control
# =================================================================

# =================================================================
# DATABASE CONFIGURATION
# =================================================================
DB_CONNECTION_STRING=Host=<your-host>;Port=5432;Database=<db-name>;Username=<user>;Password=<password>;SSL Mode=Require
REDIS_CONNECTION_STRING=<redis-host>:6379,password=<password>,ssl=true
RABBITMQ_CONNECTION_STRING=amqps://<user>:<password>@<host>:5671/<vhost>

# =================================================================
# SECURITY & AUTHENTICATION
# =================================================================
JWT_SECRET_KEY=<generate-using-script>
JWT_ISSUER=<your-domain>
JWT_AUDIENCE=<your-domain>
JWT_EXPIRATION_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7
ENCRYPTION_KEY=<generate-using-script>

# OAuth 2.0 (Optional)
OAUTH_CLIENT_ID=<your-client-id>
OAUTH_CLIENT_SECRET=<your-client-secret>
OAUTH_AUTHORITY=<identity-server-url>

# =================================================================
# EMAIL SERVICE
# =================================================================
AWS_ACCESS_KEY=<your-key>
AWS_SECRET_KEY=<your-secret>
SMTP_HOST=<smtp-server>
SMTP_PORT=587
SMTP_USERNAME=<username>
SMTP_PASSWORD=<password>

# Azure Communication Service
AZURE_COMMUNICATION_SERVICE_CONNECTION_STRING=endpoint=https://<resource-name>.communication.azure.com/;accesskey=<your-access-key>
AZURE_COMMUNICATION_SERVICE_FROM_EMAIL=<from-email-address>
AZURE_COMMUNICATION_SERVICE_FROM_NAME=<from-name>

# =================================================================
# FIRS API INTEGRATION
# =================================================================
FIRS_API_BASE_URL=<firs-api-url>
FIRS_API_KEY=<your-api-key>
FIRS_API_SECRET=<your-api-secret>

# =================================================================
# ACCESS POINT PROVIDER (APP) CONFIGURATION
# =================================================================
# APP credentials (Interswitch, BlueBridge, eTranzact, etc.) are NO LONGER
# stored in environment variables. They are managed in the database via the
# AppProviderConfigurations table and administered through the Aegis Admin
# portal by an AegisAdmin user. This includes sandbox and production
# credential sets per provider, as well as auth scheme and header configuration.
# =================================================================

# =================================================================
# APPLICATION SETTINGS
# =================================================================
DEPLOYMENT_MODE=OnPremise
ASPNETCORE_ENVIRONMENT=Production
APP_BASE_URL=https://<your-domain>

# =================================================================
# CORS CONFIGURATION
# =================================================================
CORS_ALLOWED_ORIGINS=https://<frontend-domain>

# =================================================================
# MONITORING
# =================================================================
ELASTICSEARCH_URI=https://<elasticsearch-host>:9200
ELASTICSEARCH_USERNAME=<username>
ELASTICSEARCH_PASSWORD=<password>

# =================================================================
# See .env.development and .env.production for complete examples
# Use scripts/generate-secrets.ps1 or .sh to generate secure keys
# =================================================================