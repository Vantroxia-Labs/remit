<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    =================================================================
    IIS CONFIGURATION FOR SECURITY HEADER MANAGEMENT
    =================================================================
    Addresses VAPT findings:
    - Information Disclosure through HTTP Response Headers
    - Security headers misconfiguration

    This file configures IIS to:
    1. Remove all server identification headers (Server, X-Powered-By, etc.)
    2. Add security headers at IIS level as backup to middleware
    3. Prevent information disclosure about server version and technologies
    =================================================================
  -->

  <system.webServer>
    <!--
      =================================================================
      REMOVE IIS SERVER VERSION HEADER
      =================================================================
      Prevents disclosure of IIS version (e.g., "Microsoft-IIS/10.0")
    -->
    <security>
      <requestFiltering removeServerHeader="true">
        <!--
          =================================================================
          HTTP VERB FILTERING - BLOCK DISALLOWED HTTP METHODS
          =================================================================
          CRITICAL: OPTIONS must be ALLOWED for CORS preflight requests
          Block TRACE, CONNECT and other dangerous HTTP methods at IIS level
          Allow: GET, POST, PUT, DELETE, PATCH, OPTIONS
        -->
        <verbs>
          <add verb="OPTIONS" allowed="true" />
          <add verb="TRACE" allowed="false" />
          <add verb="HEAD" allowed="false" />
          <add verb="CONNECT" allowed="false" />
        </verbs>
      </requestFiltering>
    </security>

    <!--
      =================================================================
      HTTP HEADERS CONFIGURATION
      =================================================================
      Remove information disclosure headers and add security headers
    -->
    <httpProtocol>
      <customHeaders>
        <!-- REMOVE: Information disclosure headers -->
        <remove name="Server" />
        <remove name="X-Powered-By" />
        <remove name="X-AspNet-Version" />
        <remove name="X-AspNetMvc-Version" />
        <remove name="X-AspNetCore-Version" />
        <remove name="X-XSS-Protection" />

        <!-- ADD: Security headers (backup to SecurityHeadersMiddleware) -->
        <!-- These are added at IIS level in case middleware fails -->

        <!-- Strict-Transport-Security (HSTS): Force HTTPS for 1 year -->
        <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains; preload" />

        <!-- X-Content-Type-Options: Prevent MIME sniffing -->
        <add name="X-Content-Type-Options" value="nosniff" />

        <!-- X-Frame-Options: Prevent clickjacking -->
        <add name="X-Frame-Options" value="DENY" />

        <!-- Referrer-Policy: Control referrer information -->
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />

        <!-- X-Permitted-Cross-Domain-Policies: Restrict Flash/PDF -->
        <add name="X-Permitted-Cross-Domain-Policies" value="none" />

        <!-- Permissions-Policy: Restrict browser features -->
        <add name="Permissions-Policy" value="geolocation=(), camera=(), microphone=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()" />

        <!-- Cross-Origin-Opener-Policy: Prevent cross-origin attacks -->
        <!-- Note: Changed from "same-origin" to allow CORS API requests from trusted origins -->
        <add name="Cross-Origin-Opener-Policy" value="same-origin-allow-popups" />

        <!-- Cross-Origin-Resource-Policy: Prevent resource leaks -->
        <!-- Note: Changed from "same-origin" to allow CORS API requests from trusted origins -->
        <!-- Security: CORS middleware already controls which origins can access the API -->
        <add name="Cross-Origin-Resource-Policy" value="cross-origin" />

        <!-- Cross-Origin-Embedder-Policy: Require explicit permission -->
        <!-- Note: Changed from "require-corp" to allow CORS API requests from trusted origins -->
        <!-- Security: CORS middleware already controls which origins can access the API -->
        <add name="Cross-Origin-Embedder-Policy" value="unsafe-none" />

        <!-- X-DNS-Prefetch-Control: Disable DNS prefetching for privacy -->
        <add name="X-DNS-Prefetch-Control" value="off" />
      </customHeaders>
    </httpProtocol>

    <!--
      =================================================================
      URL REWRITE RULES - REMOVE SERVER HEADERS (DISABLED)
      =================================================================
      DISABLED: IIS URL Rewrite module may not be available on Azure App Service
      Causing HTTP 500.30 startup failure.

      Server headers are already removed by SecurityHeadersMiddleware at application level.
      See SecurityHeadersMiddleware.RemoveServerHeaders() method.
    -->
    <!--
    <rewrite>
      <outboundRules rewriteBeforeCache="true">
        <rule name="RemoveServerHeader">
          <match serverVariable="RESPONSE_SERVER" pattern=".+" />
          <action type="Rewrite" value="" />
        </rule>
        <rule name="RemoveXPoweredBy">
          <match serverVariable="RESPONSE_X-Powered-By" pattern=".+" />
          <action type="Rewrite" value="" />
        </rule>
        <rule name="RemoveXAspNetVersion">
          <match serverVariable="RESPONSE_X-AspNet-Version" pattern=".+" />
          <action type="Rewrite" value="" />
        </rule>
        <rule name="RemoveXAspNetMvcVersion">
          <match serverVariable="RESPONSE_X-AspNetMvc-Version" pattern=".+" />
          <action type="Rewrite" value="" />
        </rule>
        <rule name="RemoveXAspNetCoreVersion">
          <match serverVariable="RESPONSE_X-AspNetCore-Version" pattern=".+" />
          <action type="Rewrite" value="" />
        </rule>
      </outboundRules>
    </rewrite>
    -->

    <handlers>
      <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
    </handlers>
    <aspNetCore processPath="dotnet" arguments=".\AegisEInvoicing.Portal.API.dll" stdoutLogEnabled="true" stdoutLogFile=".\logs\stdout" hostingModel="inprocess" />
  </system.webServer>
</configuration>
